    </diagram>
    <diagram id="flux-refacto" name="03 Flux et migration">
        <mxGraphModel dx="1700" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title-flow" value="Flux runtime et sequence de refacto" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=28;fontStyle=1;fontColor=#102033;" vertex="1" parent="1">
                    <mxGeometry x="40" y="30" width="1620" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="flow-lobby" value="&lt;b&gt;LobbyPanel&lt;/b&gt;&lt;br&gt;create / join / start / restart&lt;br&gt;maze size" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6dfff;strokeColor=#9673a6;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="80" y="145" width="230" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="flow-input" value="&lt;b&gt;InputRouter&lt;/b&gt;&lt;br&gt;keyboard / gamepad / touch&lt;br&gt;move_requested" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7dd;strokeColor=#d6b656;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="80" y="285" width="230" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="flow-coordinator" value="&lt;b&gt;MazeGame coordinator&lt;/b&gt;&lt;br&gt;valide les commandes simples&lt;br&gt;relie UI, input et services" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#101c2d;strokeColor=#45d9ff;fontColor=#ffffff;fontSize=15;fontStyle=1;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="390" y="215" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="flow-network" value="&lt;b&gt;NetworkClient&lt;/b&gt;&lt;br&gt;send_json&lt;br&gt;poll WebSocket&lt;br&gt;message_received" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f3ff;strokeColor=#6c8ebf;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="720" y="215" width="230" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="flow-server" value="&lt;b&gt;Serveur autoritaire&lt;/b&gt;&lt;br&gt;Node.js WebSocket&lt;br&gt;rooms, maze, ranking, power-ups" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f7fa;strokeColor=#7a869a;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="1030" y="215" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="flow-state" value="&lt;b&gt;GameState&lt;/b&gt; (Model)&lt;br&gt;apply_room_snapshot / apply_state_snapshot&lt;br&gt;met a jour les donnees de course&lt;br&gt;fournit des queries au Controller" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e5;strokeColor=#82b366;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="720" y="430" width="270" height="116" as="geometry"/>
                </mxCell>
                <mxCell id="flow-render" value="&lt;b&gt;World renderers&lt;/b&gt;&lt;br&gt;MazeRenderer&lt;br&gt;PowerUpRenderer&lt;br&gt;PlayerRenderer&lt;br&gt;EffectsLayer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="350" y="630" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="flow-ui" value="&lt;b&gt;UI panels&lt;/b&gt;&lt;br&gt;LobbyPanel&lt;br&gt;RaceHud&lt;br&gt;ScoreboardPanel&lt;br&gt;DebugOverlay" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6dfff;strokeColor=#9673a6;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="700" y="630" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="flow-discord" value="&lt;b&gt;DiscordBridge&lt;/b&gt;&lt;br&gt;observe GameState&lt;br&gt;update presence&lt;br&gt;fournit avatars" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#efe6ff;strokeColor=#9673a6;fontColor=#102033;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="1050" y="630" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="phase-title" value="Ordre de migration conseille" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#102033;" vertex="1" parent="1">
                    <mxGeometry x="80" y="850" width="420" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="phase-1" value="&lt;b&gt;1. GameState&lt;/b&gt;&lt;br&gt;Extraire les variables de course, _apply_race_metadata et les helpers joueur local. Garder main.gd comme Controller temporaire." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5e5;strokeColor=#82b366;fontColor=#102033;fontSize=14;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="80" y="915" width="285" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="phase-2" value="&lt;b&gt;2. NetworkClient&lt;/b&gt;&lt;br&gt;Deplacer WebSocket, pending_message, _connect_and_send, _send_json, _update_network." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f3ff;strokeColor=#6c8ebf;fontColor=#102033;fontSize=14;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="395" y="915" width="285" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="phase-3" value="&lt;b&gt;3. UI scenes&lt;/b&gt;&lt;br&gt;Transformer LobbyPanel, RaceHud, ScoreboardPanel, TouchControls en .tscn + scripts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6dfff;strokeColor=#9673a6;fontColor=#102033;fontSize=14;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="710" y="915" width="285" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="phase-4" value="&lt;b&gt;4. World renderers&lt;/b&gt;&lt;br&gt;WorldRenderer extrait. Prochaine passe: le decouper en MazeRenderer, PlayerRenderer, PowerUpRenderer et EffectsLayer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontColor=#102033;fontSize=14;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="1025" y="915" width="285" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="phase-5" value="&lt;b&gt;5. Services restants&lt;/b&gt;&lt;br&gt;Extraire DiscordBridge, AudioDirector, SettingsStore puis reduire main.gd au wiring." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#102033;fontSize=14;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="1340" y="915" width="285" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="phase-note" value="Definition de fini: chaque extraction remplace des lectures directes de variables globales par des APIs claires ou des signals quand ils sont utiles, avec le meme comportement reseau et visuel qu&#39;avant." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f7fa;strokeColor=#b9c6d3;fontColor=#40566f;fontSize=15;arcSize=8;" vertex="1" parent="1">
                    <mxGeometry x="270" y="1065" width="1160" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="edge-lobby-coord" value="commands" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=2;" edge="1" parent="1" source="flow-lobby" target="flow-coordinator">
                    <mxGeometry relative="1" as="geometry"/>
