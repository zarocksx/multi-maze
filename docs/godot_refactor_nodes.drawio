                <mxCell id="edge-state-ui" value="state queries" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="game-state" target="race-hud">
